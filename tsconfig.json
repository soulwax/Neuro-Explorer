{
	"compilerOptions": {
		"esModuleInterop": true,
		"skipLibCheck": true,
		"target": "es2022",
		"allowJs": true,
		"checkJs": false,
		"resolveJsonModule": true,
		"moduleDetection": "force",
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"lib": ["dom", "dom.iterable", "ES2022"],
		"noEmit": true,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "preserve",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"types": ["node"],
		"paths": {
			"~/*": ["./src/*"]
		}
	},
	"include": [
		"**/*.d.ts",
		"next-env.d.ts",
		"src/app/**/*.ts",
		"src/app/**/*.tsx",
		"src/components/**/*.ts",
		"src/components/**/*.tsx",
		"src/core/**/*.ts",
		"src/lib/**/*.ts",
		"src/server/**/*.ts",
		"src/env.js",
		".next/types/**/*.ts",
		"open-next.config.ts"
	],
	"exclude": [
		"node_modules",
		"test"
	]
}
