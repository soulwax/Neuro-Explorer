# Cloudflare AI REST credentials for `vision` and `ask`.
# These are used in Vercel and in plain local Next.js dev.
# Cloudflare Workers deploys use the native Wrangler `AI` binding instead.
# Either pair works; the app checks the long names first.
# CLOUDFLARE_ACCOUNT_ID=""
# CLOUDFLARE_API_TOKEN=""

# CF_ACCOUNT_ID=""
# CF_API_TOKEN=""
